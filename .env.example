DISCORD_TOKEN=
DB_PATH=keywords.db
DEFAULT_COOLDOWN=30

# Holodex live notify config
# 1. Optional 按 org 一次抓所有頻道：Holodex 組織代碼
HOLODEX_ORG=hololive
# 2. Holodex channel IDs (comma separated) (if org is unset)
HOLODEX_CHANNEL_IDS=UCxxxxxx,UCyyyyyy
# 3. Holodex event notify channel IDs
#    - 直播開始
HOLODEX_NOTIFY_LIVE_CHANNEL_ID=
#    - 即將直播
HOLODEX_NOTIFY_UPCOMING_CHANNEL_ID=
#    - 影片上傳
HOLODEX_NOTIFY_UPLOAD_CHANNEL_ID=
# 3. Poll interval seconds
HOLODEX_POLL_INTERVAL=60
# 4. Optional Holodex API key (if you have one)
HOLODEX_API_KEY=